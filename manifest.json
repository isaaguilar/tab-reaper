{
  "manifest_version": 3,
  "name": "Tab Reaper",
  "version": "1.0.0",
  "description": "Automatically closes leftover browser tabs from OAuth callbacks, Slack redirects, and Zoom launchers.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://app.slack.com/*",
    "https://slack.com/*",
    "https://*.zoom.us/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
