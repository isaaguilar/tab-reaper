{
  "manifest_version": 3,
  "name": "Tab Reaper",
  "version": "1.0.2",
  "description": "Automatically closes leftover browser tabs matching user-defined URL patterns on sites you grant access to.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
